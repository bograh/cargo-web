---
import InstallCommand from './InstallCommand.astro';
---

<section class="cta corrugated">
  <div class="wrap cta__inner">
    <h2 class="cta__title">Ship your first app in ten minutes.</h2>
    <p class="cta__sub">
      One Linux host, one command, and your team has its own platform.
    </p>
    <div class="cta__actions">
      <InstallCommand />
      <a href="/docs/" class="btn btn--ghost">Read the documentation</a>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    background:
      radial-gradient(40rem 20rem at 50% 120%, rgba(245, 165, 36, 0.12), transparent 65%);
  }

  .cta__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
    padding-block: clamp(4rem, 9vw, 7rem);
  }

  .cta__title {
    font-size: clamp(1.9rem, 4.5vw, 3rem);
    letter-spacing: -0.025em;
  }

  .cta__sub {
    color: var(--muted);
    font-size: 1.05rem;
    max-width: 44ch;
  }

  .cta__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.75rem;
  }
</style>
