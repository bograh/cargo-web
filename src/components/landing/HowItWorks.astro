---
const steps = [
  {
    num: '01',
    title: 'Install',
    body: 'One script checks dependencies, prompts for your domains, generates mode-0600 secrets, and starts the stack.',
  },
  {
    num: '02',
    title: 'Connect',
    body: 'Authorize the GitHub App and pick a repo + branch — or deploy any registry image directly.',
  },
  {
    num: '03',
    title: 'Ship',
    body: 'Cargo builds, deploys, and serves your app at https://<app>.<apps-domain> with automatic SSL.',
  },
];
---

<section class="steps">
  <div class="wrap">
    <span class="chip">How it works</span>
    <h2 class="section-title">Bare metal to HTTPS in three moves</h2>
    <div class="hazard" aria-hidden="true"></div>

    <ol class="steps__list">
      {steps.map((s) => (
        <li class="steps__item">
          <span class="steps__num" aria-hidden="true">{s.num}</span>
          <div class="steps__body">
            <h3 class="steps__title">{s.title}</h3>
            <p class="steps__text">{s.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .steps {
    padding-block: clamp(3.5rem, 8vw, 6rem);
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }

  .section-title {
    font-size: clamp(1.6rem, 3.4vw, 2.3rem);
    letter-spacing: -0.02em;
    margin-top: 1rem;
  }

  .hazard {
    margin-top: 1.1rem;
  }

  .steps__list {
    list-style: none;
    margin: 2.5rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .steps__item {
    display: flex;
    gap: 1rem;
    padding: 1.4rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    border-top: 3px solid var(--amber);
  }

  .steps__num {
    font-family: var(--font-mono);
    font-size: 1.6rem;
    font-weight: 700;
    color: color-mix(in srgb, var(--amber) 70%, transparent);
    line-height: 1;
    padding-top: 0.15rem;
  }

  .steps__title {
    font-size: 1.15rem;
    margin-bottom: 0.45rem;
  }

  .steps__text {
    color: var(--muted);
    font-size: 0.94rem;
  }

  @media (max-width: 820px) {
    .steps__list {
      grid-template-columns: 1fr;
    }
  }
</style>
