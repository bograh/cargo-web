---
const features = [
  {
    title: 'Push to deploy',
    body: 'GitHub App webhooks (HMAC-validated) redeploy on every push to the tracked branch. Manual deploys too.',
    icon: 'M2 8h9M8 4l4 4-4 4M14 2v12',
  },
  {
    title: 'Dockerfile or Nixpacks',
    body: 'Builder auto-detected: your Dockerfile if present, Nixpacks otherwise. Custom context, Dockerfile path, and build args supported.',
    icon: 'M2 6h12v8H2zM5 6v8M8 6v8M11 6v8',
  },
  {
    title: 'Automatic HTTPS',
    body: 'Wildcard DNS-01 or per-domain HTTP-01 via Let\u2019s Encrypt. Custom domains attach in one click.',
    icon: 'M8 2a4 4 0 0 1 4 4v2h1a1 1 0 0 1 1 1v4a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V9a1 1 0 0 1 1-1h1V6a4 4 0 0 1 4-4zM6 8h4V6a2 2 0 1 0-4 0v2z',
  },
  {
    title: 'Live build & deploy logs',
    body: 'Streamed live over SSE and retained per deployment.',
    icon: 'M2 3h12v10H2zM4 6l3 2-3 2M8 10h4',
  },
  {
    title: 'Encrypted env vars',
    body: 'AES-256-GCM at rest. Values are write-only after saving.',
    icon: 'M8 1l5 2v4c0 4-2.2 6.4-5 8-2.8-1.6-5-4-5-8V3l5-2zM6 8l2 2 3-3',
  },
  {
    title: 'One-click rollback',
    body: 'Redeploy any previous deployment\u2019s retained image in seconds — no rebuild.',
    icon: 'M3 8a5 5 0 1 1 1.5 3.5M3 8V4m0 4h4',
  },
  {
    title: 'Managed databases',
    body: 'Provision Postgres 16/17 and Redis 7 per org; attaching injects DATABASE_URL or REDIS_URL.',
    icon: 'M8 2c3 0 5 .8 5 2s-2 2-5 2-5-.8-5-2 2-2 5-2zM3 4v8c0 1.2 2 2 5 2s5-.8 5-2V4M3 8c0 1.2 2 2 5 2s5-.8 5-2',
  },
  {
    title: 'Teams & roles',
    body: 'Organizations with owner/admin/member/viewer roles and shareable invite links.',
    icon: 'M6 7a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5zM1.5 14c0-2.5 2-4 4.5-4s4.5 1.5 4.5 4M11 7a2 2 0 1 0-.8-3.8M12.5 10c1.6.4 2.5 1.6 2.5 3.4',
  },
];
---

<section class="features">
  <div class="wrap">
    <span class="chip">Manifest</span>
    <h2 class="section-title">Everything a team needs to ship</h2>
    <div class="hazard" aria-hidden="true"></div>

    <div class="features__grid">
      {features.map((f) => (
        <div class="card features__card">
          <svg class="features__icon" viewBox="0 0 16 16" width="20" height="20" aria-hidden="true">
            <path d={f.icon} fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
          </svg>
          <h3 class="features__title">{f.title}</h3>
          <p class="features__body">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    padding-block: clamp(3.5rem, 8vw, 6rem);
    border-bottom: 1px solid var(--border);
  }

  .section-title {
    font-size: clamp(1.6rem, 3.4vw, 2.3rem);
    letter-spacing: -0.02em;
    margin-top: 1rem;
  }

  .hazard {
    margin-top: 1.1rem;
  }

  .features__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  .features__card {
    padding: 1.3rem;
    transition: border-color 160ms ease, transform 160ms ease;
  }

  .features__card:hover {
    border-color: color-mix(in srgb, var(--amber) 45%, var(--border));
    transform: translateY(-2px);
  }

  .features__icon {
    color: var(--amber);
    margin-bottom: 0.85rem;
  }

  .features__title {
    font-size: 1.02rem;
    margin-bottom: 0.4rem;
  }

  .features__body {
    color: var(--muted);
    font-size: 0.88rem;
  }

  @media (max-width: 1020px) {
    .features__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .features__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
