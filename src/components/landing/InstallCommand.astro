---
interface Props {
  command?: string;
}

const { command = 'cd deploy && ./install.sh' } = Astro.props;
---

<div class="install">
  <code class="install__command"><span class="install__prompt">$</span> {command}</code>
  <button type="button" class="install__copy" data-copy={command} aria-label="Copy install command">
    <svg class="install__icon" viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
      <rect x="5" y="5" width="9" height="9" rx="1.5" fill="none" stroke="currentColor" stroke-width="1.6"></rect>
      <path d="M11 5V3.5A1.5 1.5 0 0 0 9.5 2H3.5A1.5 1.5 0 0 0 2 3.5v6A1.5 1.5 0 0 0 3.5 11H5" fill="none" stroke="currentColor" stroke-width="1.6"></path>
    </svg>
    <span class="install__label">Copy</span>
  </button>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy ?? '';
      const label = btn.querySelector('.install__label');
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      if (label) {
        const original = label.textContent;
        label.textContent = 'Copied';
        setTimeout(() => {
          label.textContent = original;
        }, 1500);
      }
    });
  });
</script>

<style>
  .install {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.7rem 0.7rem 0.7rem 1.1rem;
    font-size: 0.95rem;
  }

  .install__command {
    font-family: var(--font-mono);
    color: var(--text);
    white-space: nowrap;
  }

  .install__prompt {
    color: var(--amber);
    font-weight: 700;
  }

  .install__copy {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--raised);
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 0.4rem 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    cursor: pointer;
    transition: color 160ms ease, border-color 160ms ease;
  }

  .install__copy:hover {
    color: var(--amber);
    border-color: color-mix(in srgb, var(--amber) 50%, transparent);
  }
</style>
