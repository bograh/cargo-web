---
const containers = [
  {
    name: 'controlplane',
    role: 'Single Go binary: API, embedded React UI, job queue, deploy engine.',
  },
  {
    name: 'db',
    role: 'Postgres 16 — platform state, job queue, migrations at startup.',
  },
  {
    name: 'traefik',
    role: 'Reverse proxy. The only container publishing host ports (80/443); automatic Let\u2019s Encrypt certificates.',
  },
];
---

<section class="arch">
  <div class="wrap">
    <span class="chip">Architecture</span>
    <h2 class="section-title">Exactly three platform containers</h2>
    <div class="hazard" aria-hidden="true"></div>

    <div class="arch__grid">
      {containers.map((c) => (
        <div class="card arch__card corrugated">
          <div class="arch__card-top">
            <span class="arch__dot" aria-hidden="true"></span>
            <h3 class="arch__name">{c.name}</h3>
          </div>
          <p class="arch__role">{c.role}</p>
        </div>
      ))}
    </div>

    <p class="arch__note">+ one container per app you deploy.</p>
  </div>
</section>

<style>
  .arch {
    padding-block: clamp(3.5rem, 8vw, 6rem);
    border-bottom: 1px solid var(--border);
  }

  .section-title {
    font-size: clamp(1.6rem, 3.4vw, 2.3rem);
    letter-spacing: -0.02em;
    margin-top: 1rem;
  }

  .hazard {
    margin-top: 1.1rem;
  }

  .arch__grid {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
  }

  /* dashed freight-line connector behind the cards */
  .arch__grid::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 4%;
    right: 4%;
    border-top: 2px dashed var(--border);
    z-index: 0;
  }

  .arch__card {
    position: relative;
    z-index: 1;
    padding: 1.4rem 1.4rem 1.5rem;
    transition: border-color 160ms ease, transform 160ms ease;
  }

  .arch__card:hover {
    border-color: color-mix(in srgb, var(--amber) 45%, var(--border));
    transform: translateY(-2px);
  }

  .arch__card-top {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.7rem;
  }

  .arch__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px color-mix(in srgb, var(--green) 70%, transparent);
  }

  .arch__name {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--amber);
  }

  .arch__role {
    color: var(--muted);
    font-size: 0.94rem;
  }

  .arch__note {
    margin-top: 1.5rem;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  @media (max-width: 820px) {
    .arch__grid {
      grid-template-columns: 1fr;
    }

    .arch__grid::before {
      display: none;
    }
  }
</style>
