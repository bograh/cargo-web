---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  const paths: { params: { slug: string | undefined }; props: { entry: (typeof docs)[number] } }[] =
    docs.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
  const intro = docs.find((e) => e.id === 'introduction');
  if (intro) {
    paths.unshift({ params: { slug: undefined }, props: { entry: intro } });
  }
  return paths;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<DocsLayout entry={entry}>
  <Content />
</DocsLayout>
